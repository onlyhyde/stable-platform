{
  "name": "@stablenet/contract-registry",
  "version": "0.1.0",
  "private": true,
  "description": "StableNet Contract Registry Service",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "registry": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli/index.ts run",
    "start": "node dist/cli/index.js",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/websocket": "^11.0.1",
    "chokidar": "^4.0.3",
    "fastify": "^5.7.4",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "yargs": "^17.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^25.3.2",
    "@types/ws": "^8.5.13",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
