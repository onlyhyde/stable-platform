# StableNet Paymaster Proxy Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# REQUIRED: Core Configuration
# =============================================================================

# Default paymaster contract address (optional if chain is supported by @stablenet/contracts)
PAYMASTER_ADDRESS=0x...

# Signer private key for signing paymaster data (required)
SIGNER_PRIVATE_KEY=0x...

# RPC URL for chain connection (required)
RPC_URL=http://localhost:8545

# =============================================================================
# Multi-Paymaster Addresses (optional)
# =============================================================================
# These are auto-resolved from @stablenet/contracts based on the first
# supported chain ID. Set ENV vars below to override the auto-resolved values.

# VERIFYING_PAYMASTER_ADDRESS=0x...
# ERC20_PAYMASTER_ADDRESS=0x...
# PERMIT2_PAYMASTER_ADDRESS=0x...
# SPONSOR_PAYMASTER_ADDRESS=0x...

# =============================================================================
# Contract Addresses (optional)
# =============================================================================
# These are auto-resolved from @stablenet/contracts based on the first
# supported chain ID. Set ENV vars below to override the auto-resolved values.

# PRICE_ORACLE_ADDRESS=0x...
# PERMIT2_CONTRACT_ADDRESS=0x...

# =============================================================================
# Server Configuration
# =============================================================================

# RPC server port (default: 4338)
PAYMASTER_PORT=4338

# Enable debug mode (default: false)
PAYMASTER_DEBUG=false

# Sponsor name displayed in responses (default: StableNet Paymaster)
PAYMASTER_SPONSOR_NAME=StableNet Paymaster

# Supported chain IDs, comma-separated (default: 8283,1,11155111,84532)
# 8283 = stablenet-local, 1 = mainnet, 11155111 = sepolia, 84532 = base-sepolia
PAYMASTER_SUPPORTED_CHAIN_IDS=8283,1,11155111,84532

# =============================================================================
# Signer Configuration
# =============================================================================

# Signature validity duration in seconds (default: 3600 = 1 hour)
PAYMASTER_VALIDITY_SECONDS=3600

# Allowed clock skew in seconds (default: 60 = 1 minute)
PAYMASTER_CLOCK_SKEW_SECONDS=60

# =============================================================================
# Policy Defaults
# =============================================================================

# Maximum gas limit per operation (default: 5000000)
PAYMASTER_DEFAULT_MAX_GAS_LIMIT=5000000

# Maximum gas cost per operation in wei (default: 1000000000000000000 = 1 ETH)
PAYMASTER_DEFAULT_MAX_GAS_COST=1000000000000000000

# Daily spending limit per sender in wei (default: 100000000000000000 = 0.1 ETH)
PAYMASTER_DEFAULT_DAILY_LIMIT_PER_SENDER=100000000000000000

# Global daily spending limit in wei (default: 10000000000000000000 = 10 ETH)
PAYMASTER_DEFAULT_GLOBAL_DAILY_LIMIT=10000000000000000000

# =============================================================================
# Time Range Validation
# =============================================================================

# Maximum validity window in seconds (default: 86400 = 24 hours)
# PAYMASTER_MAX_VALIDITY_SECONDS=86400

# Minimum validity window in seconds (default: 30)
# PAYMASTER_MIN_VALIDITY_SECONDS=30

# =============================================================================
# Deposit Monitoring & Auto-Deposit
# =============================================================================

# Enable deposit balance monitoring (default: true)
# PAYMASTER_DEPOSIT_MONITOR_ENABLED=true

# Polling interval in ms (default: 30000 = 30s)
# PAYMASTER_DEPOSIT_MONITOR_POLL_MS=30000

# Minimum deposit threshold in wei (default: 10000000000000000 = 0.01 ETH)
# PAYMASTER_DEPOSIT_MIN_THRESHOLD=10000000000000000

# Reject signing when deposit is below threshold (default: false)
# PAYMASTER_DEPOSIT_REJECT_ON_LOW=false

# Enable automatic depositTo when balance is low (default: false)
# PoC reuses SIGNER_PRIVATE_KEY; production should use a separate funding key.
# PAYMASTER_DEPOSIT_AUTO_ENABLED=false

# Amount to auto-deposit in wei (default: 100000000000000000 = 0.1 ETH)
# PAYMASTER_DEPOSIT_AUTO_AMOUNT=100000000000000000

# Cooldown between auto-deposits in ms (default: 300000 = 5 min)
# PAYMASTER_DEPOSIT_AUTO_COOLDOWN_MS=300000

# =============================================================================
# Reservation Persistence
# =============================================================================

# Directory for JSON-based reservation persistence (disabled if not set).
# When set, pending reservations survive service restarts.
# PAYMASTER_RESERVATION_DATA_DIR=./data
