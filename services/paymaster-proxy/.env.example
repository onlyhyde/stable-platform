# StableNet Paymaster Proxy Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# REQUIRED: Core Configuration
# =============================================================================

# Paymaster contract address (required)
PAYMASTER_ADDRESS=0x...

# Signer private key for signing paymaster data (required)
SIGNER_PRIVATE_KEY=0x...

# RPC URL for chain connection (required)
RPC_URL=http://localhost:8545

# =============================================================================
# Server Configuration
# =============================================================================

# RPC server port (default: 4338)
PAYMASTER_PORT=4338

# Enable debug mode (default: false)
PAYMASTER_DEBUG=false

# Sponsor name displayed in responses (default: StableNet Paymaster)
PAYMASTER_SPONSOR_NAME=StableNet Paymaster

# Supported chain IDs, comma-separated (default: 8283,1,11155111,84532)
# 8283 = stablenet-local, 1 = mainnet, 11155111 = sepolia, 84532 = base-sepolia
PAYMASTER_SUPPORTED_CHAIN_IDS=8283,1,11155111,84532

# =============================================================================
# Signer Configuration
# =============================================================================

# Signature validity duration in seconds (default: 3600 = 1 hour)
PAYMASTER_VALIDITY_SECONDS=3600

# Allowed clock skew in seconds (default: 60 = 1 minute)
PAYMASTER_CLOCK_SKEW_SECONDS=60

# =============================================================================
# Policy Defaults
# =============================================================================

# Maximum gas limit per operation (default: 5000000)
PAYMASTER_DEFAULT_MAX_GAS_LIMIT=5000000

# Maximum gas cost per operation in wei (default: 1000000000000000000 = 1 ETH)
PAYMASTER_DEFAULT_MAX_GAS_COST=1000000000000000000

# Daily spending limit per sender in wei (default: 100000000000000000 = 0.1 ETH)
PAYMASTER_DEFAULT_DAILY_LIMIT_PER_SENDER=100000000000000000

# Global daily spending limit in wei (default: 10000000000000000000 = 10 ETH)
PAYMASTER_DEFAULT_GLOBAL_DAILY_LIMIT=10000000000000000000
