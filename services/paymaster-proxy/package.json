{
  "name": "@stablenet/paymaster-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "StableNet ERC-7677 Paymaster Proxy Service",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "paymaster-proxy": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch --env-file=.env src/cli/index.ts run",
    "start": "node --env-file=.env dist/cli/index.js run",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@stablenet/contracts": "workspace:*",
    "@stablenet/core": "workspace:*",
    "hono": "^4.12.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "viem": "^2.46.3",
    "yargs": "^17.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.2",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
