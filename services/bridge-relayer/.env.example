# Bridge Relayer Configuration

# Server
PORT=8080
GIN_MODE=debug  # debug, release, test
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# Ethereum Configuration
SOURCE_RPC_URL=http://localhost:8545
TARGET_RPC_URL=http://localhost:8546
SOURCE_CHAIN_ID=1
TARGET_CHAIN_ID=137
RELAYER_PRIVATE_KEY=
GAS_LIMIT_BUFFER=50000
MAX_GAS_PRICE_GWEI=500
CONFIRM_BLOCKS=12

# MPC Configuration
MPC_SIGNER_ENDPOINTS=http://localhost:9001,http://localhost:9002,http://localhost:9003,http://localhost:9004,http://localhost:9005,http://localhost:9006,http://localhost:9007
MPC_THRESHOLD=5
MPC_TOTAL_SIGNERS=7
MPC_TIMEOUT=30s

# Contract Addresses
CONTRACT_SECURE_BRIDGE=0x
CONTRACT_BRIDGE_VALIDATOR=0x
CONTRACT_BRIDGE_RATE_LIMITER=0x
CONTRACT_OPTIMISTIC_VERIFIER=0x
CONTRACT_FRAUD_PROOF_VERIFIER=0x
CONTRACT_BRIDGE_GUARDIAN=0x

# Monitor Configuration
MONITOR_POLL_INTERVAL=5s
MONITOR_BLOCK_CONFIRMATIONS=12
MONITOR_MAX_BLOCK_RANGE=1000
MONITOR_RETRY_ATTEMPTS=3
MONITOR_RETRY_DELAY=5s

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
