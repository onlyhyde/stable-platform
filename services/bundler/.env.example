# StableNet Bundler Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# REQUIRED: Core Configuration
# =============================================================================

# Private key for signing bundles (required)
BUNDLER_PRIVATE_KEY=0x...

# Beneficiary address for bundle fees (required)
BUNDLER_BENEFICIARY=0x...

# =============================================================================
# Network Configuration
# =============================================================================

# Network name: local, devnet, sepolia, mainnet (default: devnet)
BUNDLER_NETWORK=devnet

# Chain ID (overrides RPC-reported chainId, recommended for custom chains)
# BUNDLER_CHAIN_ID=8283

# RPC URL (overrides network preset)
# BUNDLER_RPC_URL=http://localhost:8545

# Native currency symbol (default: ETH)
# BUNDLER_NATIVE_CURRENCY_SYMBOL=ETH

# EntryPoint address(es), comma-separated (overrides network preset)
# BUNDLER_ENTRY_POINT=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# =============================================================================
# Server Configuration
# =============================================================================

# RPC server port (default: 4337)
BUNDLER_PORT=4337

# Log level: debug, info, warn, error (default: info)
BUNDLER_LOG_LEVEL=info

# Enable debug mode (default: false)
BUNDLER_DEBUG=false

# Max request body size in bytes (default: 1048576 = 1MB)
BUNDLER_BODY_LIMIT=1048576

# Rate limiting: max requests per window (default: 100)
BUNDLER_RATE_LIMIT_MAX=100

# Rate limiting: window duration in ms (default: 60000 = 1 min)
BUNDLER_RATE_LIMIT_WINDOW_MS=60000

# Transaction timeout in ms (default: 60000)
BUNDLER_TX_TIMEOUT_MS=60000

# CORS allowed origins, comma-separated (default: localhost only)
# Use "*" to allow all origins (not recommended for production)
# BUNDLER_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Bundle Configuration
# =============================================================================

# Minimum bundler balance in wei (default: 100000000000000000 = 0.1 ETH)
# BUNDLER_MIN_BALANCE=100000000000000000

# Bundle creation interval in ms (default: 1000)
# BUNDLER_BUNDLE_INTERVAL=1000

# Maximum UserOps per bundle (default: 10)
# BUNDLER_MAX_BUNDLE_SIZE=10

# =============================================================================
# Validation Limits
# =============================================================================

# Minimum callGasLimit (default: 9000)
# BUNDLER_MIN_CALL_GAS_LIMIT=9000

# Minimum verificationGasLimit (default: 10000)
# BUNDLER_MIN_VERIFICATION_GAS_LIMIT=10000

# Minimum preVerificationGas (default: 21000)
# BUNDLER_MIN_PRE_VERIFICATION_GAS=21000

# Minimum signature length in hex chars (default: 132)
# BUNDLER_MIN_SIGNATURE_LENGTH=132

# Maximum signature length in hex chars (default: 4098 = 2KB)
# BUNDLER_MAX_SIGNATURE_LENGTH=4098

# Maximum callData length in hex chars (default: 102402 = 50KB)
# BUNDLER_MAX_CALLDATA_LENGTH=102402

# Maximum factoryData length in hex chars (default: 102402 = 50KB)
# BUNDLER_MAX_FACTORY_DATA_LENGTH=102402

# Maximum paymasterData length in hex chars (default: 20482 = 10KB)
# BUNDLER_MAX_PAYMASTER_DATA_LENGTH=20482

# Maximum verification gas per operation (default: 10000000)
# BUNDLER_MAX_VERIFICATION_GAS=10000000

# Maximum gas per bundle (default: 30000000)
# BUNDLER_MAX_BUNDLE_GAS=30000000

# Minimum seconds before validUntil (default: 30)
# BUNDLER_MIN_VALID_UNTIL_BUFFER=30

# Maximum nonce gap from on-chain (default: 10)
# BUNDLER_MAX_NONCE_GAP=10

# =============================================================================
# Reputation System
# =============================================================================

# Minimum inclusion ratio denominator (default: 10)
# BUNDLER_REP_MIN_INCLUSION_DENOMINATOR=10

# Slack before throttling (default: 10)
# BUNDLER_REP_THROTTLING_SLACK=10

# Additional slack before banning (default: 50)
# BUNDLER_REP_BAN_SLACK=50

# Minimum stake in wei (default: 100000000000000000 = 0.1 ETH)
# BUNDLER_REP_MIN_STAKE=100000000000000000

# Minimum unstake delay in seconds (default: 86400 = 1 day)
# BUNDLER_REP_MIN_UNSTAKE_DELAY=86400

# Decay interval in ms (default: 0 = disabled)
# BUNDLER_REP_DECAY_INTERVAL_MS=0

# Decay amount per interval (default: 0)
# BUNDLER_REP_DECAY_AMOUNT=0

# Throttle auto-release duration in ms (default: 0 = disabled)
# BUNDLER_REP_THROTTLE_AUTO_RELEASE_MS=0

# =============================================================================
# Mempool Configuration
# =============================================================================

# Maximum UserOps in mempool (default: 10000)
# BUNDLER_MEMPOOL_MAX_SIZE=10000

# Maximum pending ops per sender (default: 4)
# BUNDLER_MEMPOOL_MAX_OPS_PER_SENDER=4

# TTL for pending ops in ms (default: 1800000 = 30 min)
# BUNDLER_MEMPOOL_TTL_MS=1800000

# Minimum gas price increase % for replacement (default: 10)
# BUNDLER_MEMPOOL_MIN_GAS_PRICE_INCREASE=10

# Eviction interval in ms (default: 60000)
# BUNDLER_MEMPOOL_EVICTION_INTERVAL_MS=60000

# Enable nonce continuity validation (default: false)
# BUNDLER_MEMPOOL_VALIDATE_NONCE_CONTINUITY=false

# Maximum allowed nonce gap (default: 0)
# BUNDLER_MEMPOOL_MAX_NONCE_GAP=0

# Priority strategy: gas_price|priority_fee|profit|fifo|age_weighted (default: gas_price)
# BUNDLER_MEMPOOL_PRIORITY_STRATEGY=gas_price

# Age weight factor for age_weighted strategy (default: 0)
# BUNDLER_MEMPOOL_AGE_WEIGHT_FACTOR=0

# Max age boost in ms (default: 0 = unlimited)
# BUNDLER_MEMPOOL_MAX_AGE_BOOST_MS=0
