{
  "name": "@stablenet/bundler",
  "version": "0.1.0",
  "private": true,
  "description": "StableNet ERC-4337 Bundler Service",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bundler": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "viem": "^2.21.0",
    "yargs": "^17.7.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
