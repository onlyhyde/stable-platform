{
  "name": "@stablenet/bundler",
  "version": "0.1.0",
  "private": true,
  "description": "StableNet ERC-4337 Bundler Service",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bundler": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch --env-file=.env src/cli/index.ts run",
    "start": "node --env-file=.env dist/cli/index.js run",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:anvil": "SKIP_ANVIL_TESTS=false vitest run tests/e2e/anvil/ --timeout=60000",
    "bench": "vitest bench",
    "bench:ci": "vitest bench --reporter=json > bench-results.json",
    "profile:memory": "tsx --expose-gc scripts/memory-profile.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stablenet/contracts": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "fastify": "^5.7.4",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "viem": "^2.46.3",
    "yargs": "^17.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.2",
    "@types/yargs": "^17.0.33",
    "prool": "^0.2.2",
    "tinybench": "^6.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
