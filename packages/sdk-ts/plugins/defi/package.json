{
  "name": "@stablenet/plugin-defi",
  "version": "0.1.0",
  "private": true,
  "description": "StableNet SDK - DeFi Plugin (Executors and Hooks)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stablenet/core": "workspace:*",
    "@stablenet/sdk-types": "workspace:*",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "viem": "^2.46.3"
  }
}
