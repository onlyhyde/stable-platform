# StableNet SDK Configuration
# Copy this file to .env and customize as needed
# These environment variables override the default SDK configuration

# =============================================================================
# Anvil (Local - Chain ID 31337)
# =============================================================================

# RPC URL (default: http://127.0.0.1:8545)
# STABLENET_ANVIL_RPC_URL=http://127.0.0.1:8545

# Bundler URL (default: http://127.0.0.1:4337)
# STABLENET_ANVIL_BUNDLER_URL=http://127.0.0.1:4337

# Paymaster URL (default: http://127.0.0.1:4338)
# STABLENET_ANVIL_PAYMASTER_URL=http://127.0.0.1:4338

# Stealth Server URL (default: http://127.0.0.1:4339)
# STABLENET_ANVIL_STEALTH_SERVER_URL=http://127.0.0.1:4339

# =============================================================================
# Devnet (Chain ID 1337)
# =============================================================================

# RPC URL (default: http://localhost:8545)
# STABLENET_DEVNET_RPC_URL=http://localhost:8545

# Bundler URL (default: http://localhost:4337)
# STABLENET_DEVNET_BUNDLER_URL=http://localhost:4337

# Paymaster URL (default: http://localhost:4338)
# STABLENET_DEVNET_PAYMASTER_URL=http://localhost:4338

# Stealth Server URL (default: http://localhost:4339)
# STABLENET_DEVNET_STEALTH_SERVER_URL=http://localhost:4339

# =============================================================================
# Sepolia (Chain ID 11155111)
# =============================================================================

# RPC URL (default: https://rpc.sepolia.org)
# STABLENET_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Bundler URL (default: https://bundler.sepolia.stablenet.dev)
# STABLENET_SEPOLIA_BUNDLER_URL=https://bundler.sepolia.stablenet.dev

# Paymaster URL (default: https://paymaster.sepolia.stablenet.dev)
# STABLENET_SEPOLIA_PAYMASTER_URL=https://paymaster.sepolia.stablenet.dev

# Stealth Server URL (default: https://stealth.sepolia.stablenet.dev)
# STABLENET_SEPOLIA_STEALTH_SERVER_URL=https://stealth.sepolia.stablenet.dev

# Explorer URL (default: https://sepolia.etherscan.io)
# STABLENET_SEPOLIA_EXPLORER_URL=https://sepolia.etherscan.io

# =============================================================================
# Mainnet (Chain ID 1)
# =============================================================================

# RPC URL (default: https://eth.llamarpc.com)
# STABLENET_MAINNET_RPC_URL=https://eth.llamarpc.com

# Bundler URL (default: https://bundler.mainnet.stablenet.dev)
# STABLENET_MAINNET_BUNDLER_URL=https://bundler.mainnet.stablenet.dev

# Paymaster URL (default: https://paymaster.mainnet.stablenet.dev)
# STABLENET_MAINNET_PAYMASTER_URL=https://paymaster.mainnet.stablenet.dev

# Stealth Server URL (default: https://stealth.mainnet.stablenet.dev)
# STABLENET_MAINNET_STEALTH_SERVER_URL=https://stealth.mainnet.stablenet.dev

# Explorer URL (default: https://etherscan.io)
# STABLENET_MAINNET_EXPLORER_URL=https://etherscan.io

# =============================================================================
# General
# =============================================================================

# Default chain ID for new wallets (default: 31337 = Anvil)
# STABLENET_DEFAULT_CHAIN_ID=31337
