{
  "name": "@stablenet/config",
  "version": "0.1.0",
  "private": true,
  "description": "StableNet - Shared Configuration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stablenet/contracts": "workspace:*",
    "@stablenet/types": "workspace:*",
    "viem": "^2.47.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
