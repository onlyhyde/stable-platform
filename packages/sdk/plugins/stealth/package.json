{
  "name": "@stablenet/plugin-stealth",
  "version": "0.1.0",
  "private": true,
  "description": "StableNet SDK - Stealth Address Plugin (EIP-5564/EIP-6538)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/curves": "^1.7.0",
    "@noble/hashes": "^1.6.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  },
  "peerDependencies": {
    "viem": "^2.21.0"
  }
}
