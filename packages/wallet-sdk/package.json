{
  "name": "@stablenet/wallet-sdk",
  "version": "0.1.0",
  "description": "StableNet Wallet SDK for dApp integration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./wagmi": {
      "import": "./dist/wagmi.js",
      "types": "./dist/wagmi.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@stablenet/core": ">=0.1.0",
    "@stablenet/sdk-types": ">=0.1.0",
    "react": ">=18.0.0",
    "viem": ">=2.0.0",
    "@wagmi/core": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@wagmi/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stablenet/core": "workspace:*",
    "@stablenet/sdk-types": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@wagmi/core": "^3.4.0",
    "jsdom": "^25.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "viem": "^2.46.3",
    "vitest": "^2.1.8",
    "wagmi": "^3.5.0"
  },
  "keywords": [
    "ethereum",
    "wallet",
    "web3",
    "eip-1193",
    "stablenet"
  ],
  "license": "MIT"
}
