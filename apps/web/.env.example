# StableNet Web Environment Variables

# WalletConnect Project ID
# Get yours at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# =============================================================================
# Devnet Configuration (Chain ID 31337)
# =============================================================================

# Service URLs
# NEXT_PUBLIC_DEVNET_RPC_URL=http://localhost:8545
# NEXT_PUBLIC_DEVNET_BUNDLER_URL=http://localhost:4337
# NEXT_PUBLIC_DEVNET_PAYMASTER_URL=http://localhost:4338
# NEXT_PUBLIC_DEVNET_STEALTH_SERVER_URL=http://localhost:4339
# NEXT_PUBLIC_DEVNET_EXPLORER_URL=http://localhost:4000

# Contract Addresses
# NEXT_PUBLIC_DEVNET_ENTRY_POINT=0x5FbDB2315678afecb367f032d93F642f64180aa3
# NEXT_PUBLIC_DEVNET_ACCOUNT_FACTORY=0xfaAddC93baf78e89DCf37bA67943E1bE8F37Bb8c
# NEXT_PUBLIC_DEVNET_PAYMASTER=0x2dd78fd9b8f40659af32ef98555b8b31bc97a351
# NEXT_PUBLIC_DEVNET_STEALTH_ANNOUNCER=0x8fc8cfb7f7362e44e472c690a6e025b80e406458
# NEXT_PUBLIC_DEVNET_STEALTH_REGISTRY=0xc7143d5ba86553c06f5730c8dc9f8187a621a8d4

