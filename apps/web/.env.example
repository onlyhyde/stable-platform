# =============================================================================
# App Configuration
# =============================================================================

# Default slippage percentage (default: 0.5)
# NEXT_PUBLIC_DEFAULT_SLIPPAGE=0.5

# Maximum slippage percentage (default: 50)
# NEXT_PUBLIC_MAX_SLIPPAGE=50

# Transaction timeout in milliseconds (default: 60000)
# NEXT_PUBLIC_TX_TIMEOUT=60000

# Default chain ID (default: 31337 for Devnet)
# NEXT_PUBLIC_DEFAULT_CHAIN_ID=31337
