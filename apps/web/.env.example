# StableNet Web Environment Variables
#
# All values below have defaults in lib/config/env.ts.
# Only set variables here if you need to override the defaults.
# Contract addresses are sourced from @stablenet/contracts at runtime.

# =============================================================================
# Local Configuration (Chain ID 8283 - StableNet Local)
# =============================================================================

# Service URLs
# NEXT_PUBLIC_LOCAL_RPC_URL=http://127.0.0.1:8501
# NEXT_PUBLIC_LOCAL_BUNDLER_URL=http://127.0.0.1:4337
# NEXT_PUBLIC_LOCAL_PAYMASTER_URL=http://127.0.0.1:4338
# NEXT_PUBLIC_LOCAL_STEALTH_SERVER_URL=http://127.0.0.1:4339
# NEXT_PUBLIC_LOCAL_EXPLORER_URL=http://127.0.0.1:3001
# NEXT_PUBLIC_LOCAL_INDEXER_URL=http://127.0.0.1:8080/api
# NEXT_PUBLIC_LOCAL_ORDER_ROUTER_URL=http://localhost:8087

# =============================================================================
# Testnet Configuration (Chain ID 82830 - StableNet Testnet)
# =============================================================================

# Service URLs
# NEXT_PUBLIC_TESTNET_RPC_URL=https://rpc.testnet.stablenet.dev
# NEXT_PUBLIC_TESTNET_BUNDLER_URL=https://bundler.testnet.stablenet.dev
# NEXT_PUBLIC_TESTNET_PAYMASTER_URL=https://paymaster.testnet.stablenet.dev
# NEXT_PUBLIC_TESTNET_STEALTH_SERVER_URL=https://stealth.testnet.stablenet.dev
# NEXT_PUBLIC_TESTNET_EXPLORER_URL=https://explorer.testnet.stablenet.dev
# NEXT_PUBLIC_TESTNET_INDEXER_URL=https://indexer.testnet.stablenet.dev/api
# NEXT_PUBLIC_TESTNET_ORDER_ROUTER_URL=http://localhost:8087

# =============================================================================
# App Configuration
# =============================================================================

# Default slippage percentage (default: 0.5)
# NEXT_PUBLIC_DEFAULT_SLIPPAGE=0.5

# Maximum slippage percentage (default: 50)
# NEXT_PUBLIC_MAX_SLIPPAGE=50

# Transaction timeout in milliseconds (default: 60000)
# NEXT_PUBLIC_TX_TIMEOUT=60000

# Default chain ID (default: 8283 for StableNet Local)
# NEXT_PUBLIC_DEFAULT_CHAIN_ID=8283
