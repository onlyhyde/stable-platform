# StableNet Wallet Extension Configuration
# Copy this file to .env and customize as needed
# These environment variables are used at build time (Vite)

# =============================================================================
# API Configuration
# =============================================================================

# Bank Simulator API URL (default: http://localhost:4350/api/v1)
# VITE_WALLET_BANK_API_URL=http://localhost:4350/api/v1

# OnRamp Simulator API URL (default: http://localhost:4352/api/v1)
# VITE_WALLET_ONRAMP_API_URL=http://localhost:4352/api/v1

# =============================================================================
# StableNet Local Configuration (Chain ID 8283)
# =============================================================================

# VITE_WALLET_LOCAL_RPC_URL=http://localhost:8501
# VITE_WALLET_LOCAL_BUNDLER_URL=http://localhost:4337
# VITE_WALLET_LOCAL_PAYMASTER_URL=http://localhost:4338
# VITE_WALLET_LOCAL_STEALTH_SERVER_URL=http://localhost:4339

# =============================================================================
# Devnet Configuration (Chain ID 31337)
# =============================================================================

# VITE_WALLET_DEVNET_RPC_URL=http://localhost:8545
# VITE_WALLET_DEVNET_BUNDLER_URL=http://localhost:4337
# VITE_WALLET_DEVNET_PAYMASTER_URL=http://localhost:4338
# VITE_WALLET_DEVNET_STEALTH_SERVER_URL=http://localhost:4339

# =============================================================================
# Testnet Configuration (Chain ID 11155111 - Sepolia)
# =============================================================================

# VITE_WALLET_TESTNET_RPC_URL=https://testnet.stablenet.io/rpc
# VITE_WALLET_TESTNET_BUNDLER_URL=https://testnet.stablenet.io/bundler
# VITE_WALLET_TESTNET_PAYMASTER_URL=https://testnet.stablenet.io/paymaster
# VITE_WALLET_TESTNET_STEALTH_SERVER_URL=https://testnet.stablenet.io/stealth

# =============================================================================
# Timeouts and Intervals
# =============================================================================

# API timeout in milliseconds (default: 30000)
# VITE_WALLET_API_TIMEOUT_MS=30000

# Gas price polling interval in milliseconds (default: 15000)
# VITE_WALLET_GAS_POLLING_INTERVAL_MS=15000

# Approval expiry time in milliseconds (default: 300000 = 5 minutes)
# VITE_WALLET_APPROVAL_EXPIRY_MS=300000

# =============================================================================
# Security Configuration
# =============================================================================

# Auto-lock timeout in minutes (default: 5)
# VITE_WALLET_AUTO_LOCK_MINUTES=5

# PBKDF2 iterations for key derivation (default: 100000)
# VITE_WALLET_PBKDF2_ITERATIONS=100000

# =============================================================================
# History Limits
# =============================================================================

# Maximum gas price history entries (default: 100)
# VITE_WALLET_GAS_HISTORY_MAX_LENGTH=100

# Maximum approval history entries (default: 50)
# VITE_WALLET_APPROVAL_HISTORY_MAX_LENGTH=50
