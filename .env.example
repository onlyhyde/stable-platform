# StableNet Platform Environment Configuration
# Copy this file to .env and update values for your environment

# ===================
# Network Configuration
# ===================
# StableNet Local (Chain ID 8283) - Primary development chain
STABLENET_RPC_URL=http://localhost:8501
CHAIN_ID=8283
BUNDLER_NETWORK=local

# SDK Environment Overrides (StableNet Local)
STABLENET_LOCAL_RPC_URL=http://localhost:8501
STABLENET_LOCAL_BUNDLER_URL=http://localhost:4337
STABLENET_LOCAL_PAYMASTER_URL=http://localhost:4338
STABLENET_LOCAL_STEALTH_SERVER_URL=http://localhost:4339
STABLENET_LOCAL_EXPLORER_URL=http://localhost:3001
STABLENET_LOCAL_INDEXER_URL=http://localhost:8080
STABLENET_DEFAULT_CHAIN_ID=8283

# Anvil fallback (Chain ID 31337) - if you need Anvil alongside
# STABLENET_ANVIL_RPC_URL=http://localhost:8545

# ===================
# Contract Addresses
# ===================
# Contract addresses are auto-generated from Foundry deployment output.
# Run: pnpm generate (in packages/contracts)
# This reads {DEPLOYMENT_DIR}/{CHAIN_ID}/addresses.json and generates:
#   - packages/contracts/src/generated/addresses.ts (TypeScript)
#   - .env.contracts (env vars for docker-compose / Go services)
#
# After generating, append to your .env:
#   cat .env.contracts >> .env

# Path to Foundry deployment output directory (relative to monorepo root)
DEPLOYMENT_DIR=../poc-contract/deployments

# ===================
# Service Configuration
# ===================
BUNDLER_PORT=4337
BUNDLER_URL=http://localhost:4337
BUNDLER_RPC_URL=http://localhost:8501
# CORS allowed origins (comma-separated). Use "*" for all origins (NOT recommended for production)
BUNDLER_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
PAYMASTER_PORT=4338
PAYMASTER_URL=http://localhost:4338
PAYMASTER_SUPPORTED_CHAIN_IDS=8283,1,11155111
STEALTH_SERVER_PORT=4339
ORDER_ROUTER_PORT=4340
SUBSCRIPTION_EXECUTOR_PORT=4341
BRIDGE_RELAYER_PORT=4342

# Simulators
BANK_SIMULATOR_PORT=4350
PG_SIMULATOR_PORT=4351
ONRAMP_SIMULATOR_PORT=4352

# Simulator inter-service URLs
BANK_SIMULATOR_URL=http://localhost:4350
PG_SIMULATOR_URL=http://localhost:4351
ONRAMP_SIMULATOR_URL=http://localhost:4352

# ===================
# Simulator Webhook Secrets
# ===================
# SECURITY WARNING:
#   - These secrets are used to verify webhook authenticity
#   - The example values below are for LOCAL DEVELOPMENT ONLY
#   - For production: use strong, unique secrets (32+ chars, random)
BANK_WEBHOOK_SECRET=bank-webhook-secret-dev
PG_WEBHOOK_SECRET=pg-webhook-secret-dev
ONRAMP_WEBHOOK_SECRET=onramp-webhook-secret-dev

# ===================
# Database (PostgreSQL)
# ===================
# SECURITY WARNING:
#   - POSTGRES_PASSWORD is REQUIRED (no default in docker-compose.yml)
#   - The example password below is for LOCAL DEVELOPMENT ONLY
#   - For production: use a strong password (32+ chars, random)
#   - For production: enable SSL (sslmode=require in DATABASE_URL)
#   - For production: restrict network access and use connection pooling
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=stablenet
POSTGRES_PASSWORD=stablenet
POSTGRES_DB=stablenet
# Set to 'true' to use in-memory storage (development only)
DATABASE_USE_INMEMORY=false

# ===================
# Redis
# ===================
# SECURITY WARNING:
#   - REDIS_PASSWORD is used for Redis authentication
#   - The example password below is for LOCAL DEVELOPMENT ONLY
#   - For production: use a strong, unique password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=stablenet-redis-dev
REDIS_URL=redis://:stablenet-redis-dev@localhost:6379

# ===================
# Monitoring (Grafana)
# ===================
# SECURITY WARNING:
#   - GRAFANA_ADMIN_PASSWORD is REQUIRED when using monitoring profile
#   - The example password below is for LOCAL DEVELOPMENT ONLY
#   - For production: use a strong, unique password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin-dev-changeme

# ===================
# API Keys (Optional - for mainnet/testnet)
# ===================
# ONEINCH_API_KEY=
# ZEROX_API_KEY=
# ALCHEMY_API_KEY=

# ===================
# Private Keys (REQUIRED)
# ===================
# SECURITY: These are well-known test account keys.
#   - ONLY use for local development.
#   - NEVER use on mainnet or public testnets - funds WILL be stolen.
#   - For production, generate new keys and store in a secret manager.
#   - docker-compose.yml requires these variables (no defaults).
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
BUNDLER_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6
PAYMASTER_SIGNER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
EXECUTOR_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
RELAYER_PRIVATE_KEY=0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926a

# ===================
# Subscription System Contracts
# ===================
SUBSCRIPTION_MANAGER_ADDRESS=
RECURRING_PAYMENT_EXECUTOR_ADDRESS=

# ===================
# Bridge System Contracts
# ===================
CONTRACT_SECURE_BRIDGE=
CONTRACT_BRIDGE_VALIDATOR=
CONTRACT_BRIDGE_RATE_LIMITER=
CONTRACT_OPTIMISTIC_VERIFIER=
CONTRACT_FRAUD_PROOF_VERIFIER=
CONTRACT_BRIDGE_GUARDIAN=

# ===================
# Bridge Configuration
# ===================
SOURCE_RPC_URL=http://localhost:8501
SOURCE_CHAIN_ID=8283
TARGET_RPC_URL=http://localhost:8546
TARGET_CHAIN_ID=31338
