{
  "name": "stable-platform",
  "version": "0.1.0",
  "private": true,
  "description": "StableNet PoC Platform - ERC-4337 Account Abstraction with Privacy Features",
  "keywords": ["stablenet", "erc-4337", "account-abstraction", "smart-account", "stealth-address"],
  "license": "MIT",
  "author": "StableNet Team",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:all": "vitest run",
    "clean": "turbo clean && rm -rf node_modules",
    "typecheck": "turbo typecheck",
    "generate": "pnpm -F @stablenet/contracts generate && pnpm -F @stablenet/contracts build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@changesets/cli": "^2.27.10",
    "turbo": "^2.8.13",
    "typescript": "^5.7.2",
    "viem": "^2.46.3",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "axios": ">=1.13.5",
      "tar": ">=7.5.8",
      "ajv": ">=8.18.0",
      "minimatch": ">=10.2.3",
      "rollup": ">=4.59.0",
      "elliptic": ">=6.6.1",
      "bn.js": ">=5.2.3"
    },
    "onlyBuiltDependencies": ["sharp", "unrs-resolver"]
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
